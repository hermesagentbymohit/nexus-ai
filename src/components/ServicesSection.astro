---
// No props needed

interface ServiceCard {
  icon: string;
  title: string;
  description: string;
  accent: 'brand' | 'accent' | 'warm';
}

const services: ServiceCard[] = [
  {
    icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
    title: "AI Agent Development",
    description: "Custom LLM agents, RAG pipelines, and multi-agent orchestration tailored to your unique business processes and data landscape.",
    accent: 'brand',
  },
  {
    icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    title: "Workflow Automation",
    description: "No-code and custom automation for CRM, ERP, and document processing — reducing manual effort by up to 80% with intelligent orchestration.",
    accent: 'accent',
  },
  {
    icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>`,
    title: "Intelligent Analytics",
    description: "Real-time dashboards, predictive modeling, and anomaly detection that transform raw data into actionable business intelligence.",
    accent: 'brand',
  },
  {
    icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>`,
    title: "Conversation AI",
    description: "Smart chatbots, voice agents, and omnichannel support systems that operate 24/7 with natural, human-level understanding.",
    accent: 'warm',
  },
  {
    icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>`,
    title: "Process Mining",
    description: "Analyze your existing workflows to uncover bottlenecks, visualize dependencies, and discover high-impact automation opportunities.",
    accent: 'accent',
  },
  {
    icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
    title: "AI Consulting & Strategy",
    description: "Strategic roadmapping, architecture design, and team augmentation to help your organization adopt AI with confidence and clarity.",
    accent: 'brand',
  },
];

const accentMap: Record<string, { bg: string; ring: string; text: string; top: string }> = {
  brand: { bg: 'bg-brand-50', ring: 'ring-brand-200', text: 'text-brand-600', top: 'bg-brand-500' },
  accent: { bg: 'bg-accent-50', ring: 'ring-accent-200', text: 'text-accent-600', top: 'bg-accent-500' },
  warm: { bg: 'bg-warm-100', ring: 'ring-warm-200', text: 'text-warm-600', top: 'bg-warm-500' },
};
---

<section id="services" class="bg-surface px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-xs font-semibold uppercase tracking-[0.12em] text-brand-600">What We Do</span>
      <h2 class="mt-4 text-4xl sm:text-5xl font-normal text-ink tracking-[-0.02em]">
        End-to-End AI Solutions<br />for Your Business
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-warm-600">
        From strategic discovery to production deployment — we engineer AI systems that drive measurable business outcomes.
      </p>
    </div>

    <!-- Services grid: alternate 4+2 layout -->
    <!-- Row 1: 4 cards (2x2 on md+) -->
    <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 gap-6">
      {
        services.slice(0, 4).map((service, i) => {
          const a = accentMap[service.accent];
          return (
            <div class={`group relative rounded-2xl border border-border/80 bg-surface p-7 transition-all duration-300 hover:border-brand-300 hover:shadow-lg hover:shadow-brand-100/30 hover:-translate-y-0.5 ${i === 0 ? 'sm:col-span-2 lg:col-span-1' : ''}`}>
              <!-- Tiny brand-colored top line -->
              <div class={`absolute top-0 left-6 right-6 h-0.5 ${a.top} rounded-full opacity-60 group-hover:opacity-100 transition-opacity`}></div>
              <!-- Icon -->
              <div class={`mb-5 flex h-12 w-12 items-center justify-center rounded-xl ${a.bg} ring-1 ${a.ring} transition-all duration-300 group-hover:scale-105`}>
                <span class={a.text} set:html={service.icon} />
              </div>
              <h3 class="text-xl font-normal text-ink" style="font-family: 'Instrument Serif', Georgia, 'Times New Roman', serif; letter-spacing: -0.01em;">{service.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-warm-600">{service.description}</p>
            </div>
          );
        })
      }
    </div>

    <!-- Row 2: 2 centered cards -->
    <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
      {
        services.slice(4, 6).map((service) => {
          const a = accentMap[service.accent];
          return (
            <div class={`group relative rounded-2xl border border-border/80 bg-surface p-7 transition-all duration-300 hover:border-brand-300 hover:shadow-lg hover:shadow-brand-100/30 hover:-translate-y-0.5`}>
              <div class={`absolute top-0 left-6 right-6 h-0.5 ${a.top} rounded-full opacity-60 group-hover:opacity-100 transition-opacity`}></div>
              <div class={`mb-5 flex h-12 w-12 items-center justify-center rounded-xl ${a.bg} ring-1 ${a.ring} transition-all duration-300 group-hover:scale-105`}>
                <span class={a.text} set:html={service.icon} />
              </div>
              <h3 class="text-xl font-normal text-ink" style="font-family: 'Instrument Serif', Georgia, 'Times New Roman', serif; letter-spacing: -0.01em;">{service.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-warm-600">{service.description}</p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
