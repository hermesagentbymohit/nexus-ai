---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

interface CaseStudy {
  industry: string;
  company: string;
  title: string;
  metric: string;
  description: string;
  slug: string;
}

const caseStudies: CaseStudy[] = [
  {
    industry: "Logistics & Supply Chain",
    company: "FreightFlow Logistics",
    title: "How We Built an AI Agent System That Reduced Dispatch Time by 40%",
    metric: "40% faster dispatch",
    description: "FreightFlow was managing 2,000+ daily dispatches through a manual triage process that required five coordinators working around the clock. We designed a multi-agent orchestration system that ingests incoming orders, cross-references carrier availability, optimizes routing in real time, and auto-assigns deliveries — all within 90 seconds. The system handles 85% of dispatches autonomously, freeing coordinators to focus on exceptions and high-value accounts.",
    slug: "/nexus-ai/contact",
  },
  {
    industry: "Financial Services",
    company: "Vanguard Finance",
    title: "Automated Invoice Processing That Saves 200+ Hours Per Month",
    metric: "200+ hours/month saved",
    description: "Vanguard Finance was processing 15,000 invoices monthly across 12 regional offices, with each invoice touching 3–5 people before payment. We deployed an intelligent document processing pipeline combining OCR, LLM-based extraction, and automated validation against PO data. Invoice cycle time dropped from 12 days to under 4 hours, and data entry errors — previously running at 8% — fell to 0.3%.",
    slug: "/nexus-ai/contact",
  },
  {
    industry: "Healthcare",
    company: "MedCore Health Systems",
    title: "AI-Powered Patient Scheduling That Tripled Appointment Throughput",
    metric: "3x appointment throughput",
    description: "MedCore's legacy scheduling system required patients to call during business hours, with an average hold time of 18 minutes and a 22% no-show rate. We built an intelligent scheduling agent that handles inbound and outbound calls 24/7, intelligently slots appointments based on provider availability and patient preferences, and sends automated reminders. No-show rates dropped to 4%, and patient satisfaction scores improved by 34 points.",
    slug: "/nexus-ai/contact",
  },
  {
    industry: "Manufacturing",
    company: "Precision Parts Co.",
    title: "Real-Time Quality Control Automation Cut Defects by 60%",
    metric: "60% defect reduction",
    description: "Precision Parts was losing $2.4M annually to manufacturing defects discovered too late in the production line. We deployed computer vision agents at six inspection checkpoints, connected to a real-time anomaly detection pipeline that flags deviations within 200ms. The system now catches 97% of defects before they leave the station, and automated root-cause analysis has reduced line downtime by 35%.",
    slug: "/nexus-ai/contact",
  },
];
---

<Layout
  title="Case Studies — Nexus AI"
  description="Real results from real enterprises. Explore how Nexus AI's AI agents and automation solutions have transformed logistics, finance, healthcare, and manufacturing workflows — with measurable outcomes."
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-brand-950 px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-warm-300">Case Studies</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Proven Results for<br />
          <span class="text-warm-300">Real-World Challenges</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-warm-200">
          Every engagement starts with a problem and ends with measurable impact. Here's how we've 
          helped enterprises across industries cut costs, accelerate operations, and unlock new capabilities.
        </p>
      </div>
    </section>

    <!-- Case Studies Grid -->
    <section class="bg-white px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 gap-10 lg:grid-cols-2">
          {
            caseStudies.map((study) => (
              <article class="group flex flex-col rounded-2xl border border-border bg-white overflow-hidden transition-all duration-300 hover:border-accent-200 hover:shadow-lg hover:shadow-accent-100/50 hover:-translate-y-1">
                <!-- Industry Tag -->
                <div class="px-6 pt-6">
                  <span class="inline-flex items-center rounded-full bg-warm-100 px-3.5 py-1.5 text-xs font-semibold text-brand-700">
                    {study.industry}
                  </span>
                </div>

                <div class="flex flex-1 flex-col p-6 pt-4">
                  <!-- Company -->
                  <p class="text-sm font-medium text-muted">{study.company}</p>

                  <!-- Title -->
                  <h2 class="mt-2 text-xl font-bold text-ink group-hover:text-brand-600 transition-colors">
                    <a href={study.slug}>
                      {study.title}
                    </a>
                  </h2>

                  <!-- Result Metric Badge -->
                  <div class="mt-4 inline-flex items-center gap-1.5 self-start rounded-lg bg-emerald-50 border border-emerald-200 px-3.5 py-1.5">
                    <svg class="h-4 w-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                    </svg>
                    <span class="text-sm font-semibold text-emerald-700">{study.metric}</span>
                  </div>

                  <!-- Description -->
                  <p class="mt-4 flex-1 text-sm leading-relaxed text-muted">
                    {study.description}
                  </p>

                  <!-- CTA Link -->
                  <div class="mt-6 pt-4 border-t border-border">
                    <a
                      href={study.slug}
                      class="inline-flex items-center text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors"
                    >
                      Read the Case Study
                      <svg class="ml-1.5 h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Results Summary / Stats Bar -->
    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-brand-950 px-4 sm:px-6 lg:px-8 py-20 sm:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="text-center mb-14">
          <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Our Track Record Speaks for Itself
          </h2>
        </div>
        <div class="grid grid-cols-2 gap-10 md:grid-cols-4">
          <div class="text-center">
            <p class="text-4xl font-bold tracking-tight text-white sm:text-5xl">100+</p>
            <p class="mt-2 text-sm font-medium text-warm-200">Projects Delivered</p>
          </div>
          <div class="text-center">
            <p class="text-4xl font-bold tracking-tight text-white sm:text-5xl">60%</p>
            <p class="mt-2 text-sm font-medium text-warm-200">Avg. Cost Reduction</p>
          </div>
          <div class="text-center">
            <p class="text-4xl font-bold tracking-tight text-white sm:text-5xl">3.5x</p>
            <p class="mt-2 text-sm font-medium text-warm-200">Avg. Throughput Increase</p>
          </div>
          <div class="text-center">
            <p class="text-4xl font-bold tracking-tight text-white sm:text-5xl">98%</p>
            <p class="mt-2 text-sm font-medium text-warm-200">Client Satisfaction</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-gradient-to-b from-white to-warm-50 px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
          Ready to Be Our Next Success Story?
        </h2>
        <p class="mt-4 text-lg text-muted">
          Let's identify the highest-impact automation opportunities in your organization 
          and build a roadmap to get there — starting with a no-obligation discovery session.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/nexus-ai/contact"
            class="inline-flex items-center rounded-xl bg-brand-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-brand-600/25 hover:bg-brand-700 hover:shadow-xl transition-all duration-200 active:scale-[0.97]"
          >
            Start Your Project
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="mailto:hello@nexus-ai.com"
            class="inline-flex items-center rounded-xl border-2 border-warm-200 px-8 py-4 text-base font-semibold text-ink hover:border-accent-400 hover:bg-white transition-all duration-200"
          >
            hello@nexus-ai.com
          </a>
        </div>
        <p class="mt-6 text-sm text-muted">
          All discovery sessions include a complimentary process mining assessment — a $2,500 value.
        </p>
      </div>
    </section>
  </main>
</Layout>
