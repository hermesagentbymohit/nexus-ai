---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout
  title="Contact — Nexus AI"
  description="Ready to transform your business with AI automation? Get in touch with Nexus AI for a free consultation. We'll help you identify the highest-impact opportunities."
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-brand-900 via-brand-800 to-brand-950 px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
      <div class="mx-auto max-w-4xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-warm-300">Get in Touch</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Let's Build Something<br />
          <span class="text-warm-300">Intelligent</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-warm-200">
          Whether you're exploring AI for the first time or ready to scale your automation program — 
          we're here to help. Tell us about your challenges and we'll build a roadmap together.
        </p>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="bg-white px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 gap-16 lg:grid-cols-5">
          <!-- Left Column: Contact Form -->
          <div class="lg:col-span-3">
            <h2 class="text-2xl font-bold tracking-tight text-ink sm:text-3xl">
              Tell Us About Your Project
            </h2>
            <p class="mt-3 text-base text-muted">
              Fill out the form below and a member of our team will reach out within one business day.
            </p>

            <form class="mt-10 space-y-6" method="POST" action="#">
              <!-- Name & Email Row -->
              <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                <div>
                  <label for="name" class="block text-sm font-medium text-ink">
                    Full Name <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    placeholder="Jane Smith"
                    class="mt-2 block w-full rounded-xl border border-border bg-white px-4 py-3.5 text-sm text-ink outline-none placeholder:text-muted/60 focus:border-accent-400 focus:ring-2 focus:ring-accent-500/20 transition-all"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-ink">
                    Email Address <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="jane@company.com"
                    class="mt-2 block w-full rounded-xl border border-border bg-white px-4 py-3.5 text-sm text-ink outline-none placeholder:text-muted/60 focus:border-accent-400 focus:ring-2 focus:ring-accent-500/20 transition-all"
                  />
                </div>
              </div>

              <!-- Company & Phone Row -->
              <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                <div>
                  <label for="company" class="block text-sm font-medium text-ink">
                    Company Name <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="company"
                    name="company"
                    required
                    placeholder="Acme Corp"
                    class="mt-2 block w-full rounded-xl border border-border bg-white px-4 py-3.5 text-sm text-ink outline-none placeholder:text-muted/60 focus:border-accent-400 focus:ring-2 focus:ring-accent-500/20 transition-all"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-ink">
                    Phone Number <span class="text-muted text-xs">(optional)</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="+1 (555) 123-4567"
                    class="mt-2 block w-full rounded-xl border border-border bg-white px-4 py-3.5 text-sm text-ink outline-none placeholder:text-muted/60 focus:border-accent-400 focus:ring-2 focus:ring-accent-500/20 transition-all"
                  />
                </div>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-ink">
                  Your Message <span class="text-red-500">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  placeholder="Tell us about your project, challenges, or goals. What kind of automation are you looking to implement?"
                  class="mt-2 block w-full rounded-xl border border-border bg-white px-4 py-3.5 text-sm text-ink outline-none placeholder:text-muted/60 focus:border-accent-400 focus:ring-2 focus:ring-accent-500/20 transition-all resize-y"
                ></textarea>
              </div>

              <!-- Submit -->
              <div>
                <button
                  type="submit"
                  class="inline-flex w-full items-center justify-center rounded-xl bg-brand-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-brand-600/25 hover:bg-brand-700 hover:shadow-xl transition-all duration-200 active:scale-[0.97] sm:w-auto"
                >
                  Send Message
                  <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                  </svg>
                </button>
              </div>
            </form>
          </div>

          <!-- Right Column: Contact Info & Why Work With Us -->
          <div class="lg:col-span-2">
            <!-- Contact Info Card -->
            <div class="rounded-2xl border border-border bg-surface p-8">
              <h3 class="text-lg font-semibold text-ink">Contact Information</h3>

              <div class="mt-6 space-y-6">
                <!-- Email -->
                <div class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-warm-100">
                    <svg class="h-5 w-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-ink">Email</p>
                    <a href="mailto:hello@nexus-ai.com" class="mt-1 text-sm text-brand-600 hover:text-brand-700 transition-colors">
                      hello@nexus-ai.com
                    </a>
                  </div>
                </div>

                <!-- Location -->
                <div class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-warm-100">
                    <svg class="h-5 w-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-ink">Location</p>
                    <p class="mt-1 text-sm text-muted">
                      548 Market Street, Suite 98240<br />
                      San Francisco, CA 94104
                    </p>
                  </div>
                </div>

                <!-- Phone -->
                <div class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-warm-100">
                    <svg class="h-5 w-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-ink">Phone</p>
                    <p class="mt-1 text-sm text-muted">
                      +1 (555) 639-8721
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Why Work With Us -->
            <div class="mt-8 rounded-2xl border border-border bg-white p-8">
              <h3 class="text-lg font-semibold text-ink">Why Work With Nexus AI?</h3>
              <ul class="mt-6 space-y-5">
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-warm-100">
                    <svg class="h-3.5 w-3.5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-ink">Proven Methodology</p>
                    <p class="mt-1 text-sm text-muted">
                      Our discovery-first approach means we don't write a line of code until we've mapped every workflow and identified the highest-ROI automation targets.
                    </p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-warm-100">
                    <svg class="h-3.5 w-3.5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-ink">Measurable Outcomes, Guaranteed</p>
                    <p class="mt-1 text-sm text-muted">
                      We tie our success to your KPIs. Every engagement includes defined success metrics and transparent reporting — so you always know exactly what you're getting.
                    </p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-warm-100">
                    <svg class="h-3.5 w-3.5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-ink">End-to-End Partnership</p>
                    <p class="mt-1 text-sm text-muted">
                      From strategy workshops and proof-of-concept development to production deployment and ongoing optimization — we're with you at every stage of the journey.
                    </p>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map / Office CTA -->
    <section class="bg-gradient-to-b from-warm-50 to-white px-4 sm:px-6 lg:px-8 py-20 sm:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
          Prefer a Face-to-Face Meeting?
        </h2>
        <p class="mt-4 text-lg text-muted">
          We'd love to host you at our San Francisco headquarters. Schedule a visit and we'll 
          walk you through our lab — including live demos of our latest agent systems.
        </p>
        <div class="mt-10">
          <a
            href="mailto:hello@nexus-ai.com?subject=Office%20Visit%20Request"
            class="inline-flex items-center rounded-xl border-2 border-warm-200 px-8 py-4 text-base font-semibold text-ink hover:border-accent-400 hover:bg-white transition-all duration-200"
          >
            Request a Visit
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
