---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Nexus AI — AI Automation & Agentic Solutions",
  description = "We build AI agents and automation systems that transform enterprise workflows — cutting costs by 60% and accelerating decision-making.",
  ogImage = "/og-image.png",
} = Astro.props;

const siteTitle = "Nexus AI — AI Automation & Agentic Solutions";
const fullTitle = title === siteTitle ? siteTitle : `${title} | Nexus AI`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "Nexus AI",
      url: "https://nexus-ai.com",
      logo: "https://nexus-ai.com/logo.svg",
      description: description,
      foundingDate: "2020",
      contactPoint: {
        "@type": "ContactPoint",
        telephone: "+1-555-NEXUS-AI",
        contactType: "sales",
        availableLanguage: ["English"],
      },
      sameAs: [
        "https://twitter.com/nexusai",
        "https://linkedin.com/company/nexusai",
        "https://github.com/nexusai",
      ],
    })} />
  </head>
  <body class="relative min-h-screen">
    <!-- Fixed grain overlay -->
    <div class="noise-overlay" aria-hidden="true"></div>

    <!-- Main content (above grain) -->
    <div class="relative z-0">
      <slot />
    </div>

    <!-- Footer -->
    <footer class="relative z-0 border-t-0">
      <!-- Gradient top border -->
      <div class="h-px bg-gradient-to-r from-transparent via-accent-400/30 to-transparent" aria-hidden="true"></div>

      <div class="mx-auto max-w-7xl px-4 sm:px-8 lg:px-12 py-16 lg:py-20">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-16">
          <!-- Brand -->
          <div class="md:col-span-4 lg:col-span-5">
            <span class="text-2xl font-normal text-ink" style="font-family: 'Instrument Serif', Georgia, 'Times New Roman', serif; letter-spacing: -0.02em;">
              Nexus AI
            </span>
            <p class="mt-4 text-base leading-relaxed text-muted max-w-sm">
              Building intelligent automation systems that transform how enterprises operate — with precision, purpose, and craft.
            </p>
          </div>

          <!-- Navigation columns -->
          <div class="md:col-span-8 lg:col-span-7">
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-10">
              <!-- Product -->
              <div>
                <h4 class="text-xs font-semibold uppercase tracking-[0.12em] text-warm-500">Product</h4>
                <ul class="mt-6 space-y-4">
                  <li><a href="/services" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">AI Agents</a></li>
                  <li><a href="/services" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">Automation</a></li>
                  <li><a href="/services" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">Analytics</a></li>
                  <li><a href="/services" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">Consulting</a></li>
                </ul>
              </div>

              <!-- Company -->
              <div>
                <h4 class="text-xs font-semibold uppercase tracking-[0.12em] text-warm-500">Company</h4>
                <ul class="mt-6 space-y-4">
                  <li><a href="/" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">Home</a></li>
                  <li><a href="/case-studies" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">Case Studies</a></li>
                  <li><a href="/blog" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">Blog</a></li>
                  <li><a href="/contact" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">Contact</a></li>
                </ul>
              </div>

              <!-- Legal -->
              <div>
                <h4 class="text-xs font-semibold uppercase tracking-[0.12em] text-warm-500">Legal</h4>
                <ul class="mt-6 space-y-4">
                  <li><a href="/privacy" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">Privacy Policy</a></li>
                  <li><a href="/terms" class="text-sm text-ink/70 hover:text-ink transition-all duration-200 hover:translate-x-0.5 inline-block">Terms of Service</a></li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="mt-16 lg:mt-20 pt-8 border-t border-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <p class="text-xs text-warm-400">
            &copy; {new Date().getFullYear()} Nexus AI. All rights reserved.
          </p>
          <div class="flex items-center gap-6">
            <a href="https://twitter.com/nexusai" class="text-xs text-warm-400 hover:text-ink transition-colors" target="_blank" rel="noopener noreferrer">Twitter</a>
            <a href="https://linkedin.com/company/nexusai" class="text-xs text-warm-400 hover:text-ink transition-colors" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href="https://github.com/nexusai" class="text-xs text-warm-400 hover:text-ink transition-colors" target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
